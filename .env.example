# ============================================================
# Rassvet Catalog — environment variables
# Copy this to `.env` and fill in the blanks. Railway reads vars
# from its own secrets panel in production; this file is a
# template for local dev + documentation for operators.
# ============================================================

# ── Required ────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
WEBAPP_URL=https://your-domain.com
DATABASE_PATH=./data/catalog.db
IMAGES_DIR=./images
HOST=0.0.0.0
PORT=8000

# Admin API key — gates every /api/admin/* endpoint and admin-scoped
# mutations across the API. The bot also passes this when uploading
# 1C XLS files. Required (app refuses admin requests if unset).
# Generate any 32+ char random string: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=


# ── Chat IDs (all negative numbers — Telegram group format) ──
# Admin group — receives /help (full), error alerts, support
# forwarder requests, weekly unlinked reminders.
ADMIN_GROUP_CHAT_ID=-5224656051

# Daily group — receives 10 daily upload commands (/prices,
# /stock, /cash, /fxrate, /supply, /clients, etc.), morning
# nudge, EOD check, Client Master Monday/Friday/Sunday cycle.
DAILY_GROUP_CHAT_ID=-5243912135

# Sales / Orders group — receives order notifications with
# Excel attachments, daily client sync summary.
ORDER_GROUP_CHAT_ID=-1003740010463

# 1C handlers tagged in every Sotuv order message so they don't forget to
# enter the order into 1C and reply with the confirmed Excel. Comma-sep
# telegram IDs. Defaults to Alisher + Ibrat (hardcoded in group_config.py);
# override here to rotate. Empty → tag line is omitted.
# ONEC_HANDLER_IDS=1914160011,7650055227

# Inventory group — receives 08:00 stock alerts, demand-signal
# alerts when hidden (stale/never) products get 5+ clicks.
INVENTORY_GROUP_CHAT_ID=-5133871411

# Agents group — sales agents (optional; legacy).
AGENTS_GROUP_CHAT_ID=-1003922400481

# Cashier group — Aunt + Uncle only. Hosts the bot FSM that records
# direct cash, confirms agent handovers, approves P2P submissions.
# Leave empty until the group is created and the bot is added.
CASHIER_GROUP_CHAT_ID=

# Bank-transfer group — Uchqun + Shuhrat. Sister group to cashier; hosts
# the /perevod FSM that records bank transfers from clients (gross UZS,
# accepted %, FX rate). Leave empty until the group is created.
BANK_TRANSFER_GROUP_CHAT_ID=

# Driver/agent client-location-capture group — open to anyone in the group.
# Bot runs an FSM-driven flow there: /lokatsiya → fuzzy client search →
# pick → location pin → save canonical to allowed_clients.gps_*.
# First-confirmed-locks: subsequent pins for same client are rejected
# but audited for admin renewal review. Leave empty to disable the flow.
DRIVER_GROUP_CHAT_ID=-4998450084

# Agent-approval group — Block C agent self-registration applications +
# role-related admin work. Bot must be admin in this supergroup for
# inline-button callbacks to deliver (memory: feedback_telegram_bot_supergroup_admin).
AGENT_APPROVAL_GROUP_CHAT_ID=-1003967758004

# "Taklif va Xatolar" (Feedback + Errors) supergroup — receives post-order
# feedback (FeedbackPage in cabinet) and uncaught-exception alerts via
# error_alert.py. Note: the canonical default is -1003896597497 (supergroup);
# pre-2026-04 the chat was -5085083917 but it migrated and stale fallbacks
# silently dropped messages.
ERRORS_GROUP_CHAT_ID=-1003896597497

# Report-issue group — receives /api/reports/ submissions (wrong photo,
# wrong price, etc.) and product-request submissions. Distinct from ERRORS;
# misuse of REPORT's chat ID as the ERRORS fallback was the bug at
# Error Log #46 (WRONG_FALLBACK_FROM_COPY_PASTE).
REPORT_GROUP_CHAT_ID=-5085083917

# Legal-entity bank-transfer notifications group (Stage 1-5 flow). Falls
# back to CASHIER_GROUP_CHAT_ID at consumer site if unset (handled by
# backend/services/group_config.legal_transfer_target). Leave empty until
# the dedicated group exists.
LEGAL_TRANSFER_GROUP_CHAT_ID=

# Manager direct-message ID (single user, not a group). Used by
# notify_registration.py to DM a manager when a new user registers.
# Leave empty if not used.
MANAGER_CHAT_ID=

# Owner daily-brief targets — comma-separated chat IDs that receive the
# 09:00 Tashkent reconciliation summary. Negative = group, positive = user.
# v1 test target: -1003933938202 (supergroup). Once verified, add the
# father's user ID, e.g. "-1003933938202,IXTIYOR_TG_ID".
# Empty → feature inert (no brief sent).
OWNER_DAILY_BRIEF_TARGETS=


# ── Admin user IDs (comma-separated Telegram user ids) ──────
# Users in this list get is_admin=True in ANY chat, including private DMs.
# Used for operator privileged commands (/morningbrief, /makeagent, etc.).
# Owner: Ulugbek (652836922). To find your own ID: DM @samrassvetbot
# /chatid or use a helper bot like @userinfobot.
ADMIN_IDS=

# Cashier user IDs (comma-separated). Aunt Muqaddas (275116966)
# and Uncle (21117506) for the parallel-mode launch.
CASHIER_IDS=275116966,21117506

# Bank-transfer user IDs (comma-separated). Currently includes Ulugbek
# (652836922) as the bank-transfer operator while Uchqun + Shuhrat are
# being onboarded. Replace with their real IDs once they run /chatid in
# the bank-transfer group. Pre-2026-05-11 a stale comment here labeled
# 652836922 as "Uchqun" — that was a misattribution.
BANK_TRANSFER_IDS=652836922

# Always-approved Telegram user IDs (comma-separated). Layer 4 of the
# 4-layer auth fallback (SQLite → JSON backup → Telegram CloudStorage →
# this env var). Useful for getting a known operator past app gates when
# their phone-row hasn't propagated yet. Leave empty in normal operation.
ALWAYS_APPROVED_IDS=


# ── Paths (optional — sensible defaults baked into code) ─────
# Where order PDF/Excel exports are written + served from.
EXPORT_DIR=/data/exports

# Path to the auto-saved users JSON backup (Layer 2 of the auth fallback).
# Re-written on every successful login refresh.
USERS_BACKUP_PATH=/data/users_backup.json

# File where the bot stores the timestamp of the last GitHub PAT rotation
# (used by /patcheck and the rotation reminder cron).
PAT_STAMP_FILE=/data/.pat_rotated_at


# ── Feature toggles ──────────────────────────────────────────
# Set to "0" to disable the rate-limit middleware (default: enabled).
RATE_LIMIT_ENABLED=1


# ── Test / dev helpers (optional) ────────────────────────────
# Telegram ID of a test client used by tools/smoke_test.py. Leave unset
# unless you're running the smoke-test against a real-client flow.
TEST_CLIENT_TG=

# ⚠️ FORCE_REIMPORT — DESTRUCTIVE. DO NOT SET IN PRODUCTION.
# When set to "1", import_products.py runs DELETE FROM products /
# producers / categories before re-importing. This breaks server-side
# cart persistence (cart_items.product_id becomes orphaned). This var
# was historically set in start.sh on every deploy and caused real
# damage; removed 2026-05-10. Use ONLY for manual recovery from a
# known-broken state, with explicit operator approval. Documented here
# so it's discoverable, not active by default.
# FORCE_REIMPORT=1


# ── Retention + backup knobs (optional — defaults shown) ─────
# How long to keep analytics rows before nightly prune deletes
# them. Values in days.
RETAIN_SEARCH_LOGS_DAYS=180
RETAIN_SEARCH_CLICKS_DAYS=180
RETAIN_INTEREST_CLICKS_DAYS=365
RETAIN_SUPPORT_THREADS_DAYS=90

# How many daily DB backups to keep in /data/db_backups/
DB_BACKUP_DIR=/data/db_backups
DB_BACKUP_KEEP=14

# Popularity-score computation window (days). Drives
# search-result ordering via tools/update_popularity.py.
POPULARITY_WINDOW_DAYS=180
