# ============================================================
# Rassvet Catalog — environment variables
# Copy this to `.env` and fill in the blanks. Railway reads vars
# from its own secrets panel in production; this file is a
# template for local dev + documentation for operators.
# ============================================================

# ── Required ────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
WEBAPP_URL=https://your-domain.com
DATABASE_PATH=./data/catalog.db
IMAGES_DIR=./images
HOST=0.0.0.0
PORT=8000


# ── Chat IDs (all negative numbers — Telegram group format) ──
# Admin group — receives /help (full), error alerts, support
# forwarder requests, weekly unlinked reminders.
ADMIN_GROUP_CHAT_ID=-5224656051

# Daily group — receives 10 daily upload commands (/prices,
# /stock, /cash, /fxrate, /supply, /clients, etc.), morning
# nudge, EOD check, Client Master Monday/Friday/Sunday cycle.
DAILY_GROUP_CHAT_ID=-5243912135

# Sales / Orders group — receives order notifications with
# Excel attachments, daily client sync summary.
ORDER_GROUP_CHAT_ID=-1003740010463

# Inventory group — receives 08:00 stock alerts, demand-signal
# alerts when hidden (stale/never) products get 5+ clicks.
INVENTORY_GROUP_CHAT_ID=-5133871411

# Agents group — sales agents (optional; legacy).
AGENTS_GROUP_CHAT_ID=-1003922400481

# Cashier group — Aunt + Uncle only. Hosts the bot FSM that records
# direct cash, confirms agent handovers, approves P2P submissions.
# Leave empty until the group is created and the bot is added.
CASHIER_GROUP_CHAT_ID=


# ── Admin user IDs (comma-separated Telegram user ids) ──────
# Users in this list get is_admin=True in ANY chat, including
# private DMs. Used for operator privileged commands.
ADMIN_IDS=

# Cashier user IDs (comma-separated). Aunt Muqaddas (275116966)
# and Uncle (21117506) for the parallel-mode launch.
CASHIER_IDS=275116966,21117506


# ── Retention + backup knobs (optional — defaults shown) ─────
# How long to keep analytics rows before nightly prune deletes
# them. Values in days.
RETAIN_SEARCH_LOGS_DAYS=180
RETAIN_SEARCH_CLICKS_DAYS=180
RETAIN_INTEREST_CLICKS_DAYS=365
RETAIN_SUPPORT_THREADS_DAYS=90

# How many daily DB backups to keep in /data/db_backups/
DB_BACKUP_DIR=/data/db_backups
DB_BACKUP_KEEP=14

# Popularity-score computation window (days). Drives
# search-result ordering via tools/update_popularity.py.
POPULARITY_WINDOW_DAYS=180
