#!/bin/bash
# Pre-commit hook: foundation guards + Python syntax + pytest + frontend build sync.
#
# Foundation guards (added 2026-05-10 after the foundation renovation):
#   1. Schema DDL (CREATE/ALTER TABLE, CREATE INDEX) must live in
#      backend/database.py — never in routers/services. Closes the
#      manual-migration-endpoint debt class (Error Log #20, #46).
#   2. Chat-ID env-getters with hardcoded fallbacks must live in
#      backend/services/group_config.py — never duplicated across files.
#      Closes the WRONG_FALLBACK_FROM_COPY_PASTE class (Error Log #46).
#   3. Bare `check_admin_key(...)` statement-calls with return discarded
#      silently bypass auth — closes BOOL_AUTH_RESULT_DISCARDED (Error Log #51).
#   4. `F.chat.type.in_({...})` filter in bot handlers without a sibling
#      `chat.id ==` / `_CHAT_ID` gate — closes HANDLER_ORDER_SWALLOW
#      (Error Log #17/#28/#33, 3 recurrences).
#   5. Inline `fetch('/api/...)` in frontend pages/components — must go
#      through frontend/src/utils/api.js so initDataHeader stays uniform
#      (closes the CabinetPage drift class).
#
# Override env vars for the rare legitimate exception:
#   SKIP_SCHEMA_CHECK=1        — bypass the schema-DDL guard
#   SKIP_CHATID_CHECK=1        — bypass the chat-ID guard
#   SKIP_AUTHCALL_CHECK=1      — bypass the discarded-bool-auth guard
#   SKIP_CHATTYPE_CHECK=1      — bypass the chat-type-without-id guard
#   SKIP_INLINE_FETCH_CHECK=1  — bypass the frontend inline-fetch guard
#   SKIP_RUFF=1                — skip ruff lint
#   SKIP_FRONTEND_BUILD=1      — skip the frontend rebuild
#   SKIP_BUNDLE_CHECK=1        — skip the bundle-size budget check

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# ── Python interpreter resolution ─────────────────────────────────────────
# Prefer the venv (matches runtime.txt: 3.10.14) over whatever `python3` is
# on PATH (macOS ships /usr/bin/python3 = 3.9.x, which lacks our dev deps).
# Mirrors tools/audit.sh's resolution so hook + audit stay in lockstep.
if [ -x .venv/bin/python ]; then
    PY=".venv/bin/python"
elif command -v python3.10 >/dev/null; then
    PY="python3.10"
else
    PY="python3"
fi

# ── Python syntax ─────────────────────────────────────────────────────────
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -n "$STAGED_PY" ]; then
    echo "🔍 Checking Python syntax..."
    for f in $STAGED_PY; do
        if [ -f "$f" ]; then
            "$PY" -m py_compile "$f" 2>&1
            if [ $? -ne 0 ]; then
                echo "❌ Syntax error in $f"
                exit 1
            fi
        fi
    done
    echo "✅ Syntax OK"
fi

# ── Foundation guard 1: schema-change discipline ──────────────────────────
# Allowlist: backend/database.py (canonical schema home), tools/ (one-off ops).
if [ "$SKIP_SCHEMA_CHECK" != "1" ]; then
    BAD_SCHEMA=""
    for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | grep -v -E '^(backend/database\.py|tools/)'); do
        if [ -f "$f" ] && git diff --cached -- "$f" | grep -qE '^\+[^#]*\b(CREATE TABLE|ALTER TABLE|CREATE INDEX|CREATE UNIQUE INDEX)\b'; then
            BAD_SCHEMA="$BAD_SCHEMA $f"
        fi
    done
    if [ -n "$BAD_SCHEMA" ]; then
        echo "❌ Schema DDL added outside backend/database.py:"
        for f in $BAD_SCHEMA; do echo "    $f"; done
        echo ""
        echo "   Schema changes belong in backend/database.py:init_db() under"
        echo "   an 'if current < N' migration block, with SCHEMA_VERSION bumped."
        echo "   This prevents the manual-migration-endpoint debt class"
        echo "   (Error Log #20 client_payments, #46 real_orders)."
        echo "   Override (rare): SKIP_SCHEMA_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Foundation guard 2: chat-ID centralization ────────────────────────────
# Allowlist: backend/services/group_config.py (canonical home).
# Pattern matched: os.getenv("..._CHAT_ID", "fallback-with-content")
# A presence check like os.getenv("X_CHAT_ID") is not None is fine — only
# fallback-with-string-content triggers (that's the duplication source).
if [ "$SKIP_CHATID_CHECK" != "1" ]; then
    BAD_CHATID=""
    for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | grep -v -E '^backend/services/group_config\.py$'); do
        if [ -f "$f" ] && git diff --cached -- "$f" | grep -qE '^\+[^#]*os\.getenv\("[A-Z_]*CHAT_ID"[[:space:]]*,[[:space:]]*"[^"]+"\)'; then
            BAD_CHATID="$BAD_CHATID $f"
        fi
    done
    if [ -n "$BAD_CHATID" ]; then
        echo "❌ Chat-ID env-getter with hardcoded fallback outside group_config.py:"
        for f in $BAD_CHATID; do echo "    $f"; done
        echo ""
        echo "   Add the constant to backend/services/group_config.py with a"
        echo "   _env_int(...) call, then import it where you need it."
        echo "   This prevents the WRONG_FALLBACK_FROM_COPY_PASTE class"
        echo "   (Error Log #46 — location.py shipped to wrong group via copy-paste)."
        echo "   Override (rare): SKIP_CHATID_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Foundation guard 3: discarded-bool-auth ───────────────────────────────
# A bare `check_admin_key(...)` call as a whole statement discards the bool
# return value and silently bypasses auth (Error Log #51).
# Correct forms (any of these pass):
#   if not check_admin_key(key): raise HTTPException(403, ...)
#   ok = check_admin_key(key)
#   assert check_admin_key(key)
# Hazard form (caught here):
#   check_admin_key(admin_key)        # ← return discarded, auth no-op
if [ "$SKIP_AUTHCALL_CHECK" != "1" ]; then
    BAD_AUTHCALL=""
    for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$'); do
        if [ -f "$f" ] && git diff --cached -- "$f" | grep -qE '^\+[[:space:]]*check_admin_key\([^)]*\)[[:space:]]*$'; then
            BAD_AUTHCALL="$BAD_AUTHCALL $f"
        fi
    done
    if [ -n "$BAD_AUTHCALL" ]; then
        echo "❌ Bare check_admin_key(...) statement-call (return value discarded):"
        for f in $BAD_AUTHCALL; do echo "    $f"; done
        echo ""
        echo "   check_admin_key() returns a bool — it does NOT raise."
        echo "   A bare statement-form call silently bypasses authentication."
        echo "   Use one of:"
        echo "     if not check_admin_key(key): raise HTTPException(403, ...)"
        echo "     auth = resolve_auth(key); if not auth or auth[\"role\"] not in (...): raise ..."
        echo "   (Error Log #51 BOOL_AUTH_RESULT_DISCARDED.)"
        echo "   Override (rare): SKIP_AUTHCALL_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Foundation guard 4: HANDLER_ORDER_SWALLOW prevention ─────────────────
# Sub-router handlers that catch a message shape in groups must gate by
# exact `chat.id == GROUP_CHAT_ID` (or chat-id-set from group_config),
# never by `chat.type.in_({"group","supergroup"})` alone — otherwise they
# eat messages from every group the bot joins. Error Log #17/#28/#33 (3
# recurrences); rule codified in .claude/rules/06-bot-operations.md.
# Heuristic: any new `F.chat.type.in_(...)` filter in bot/*.py must appear
# in a diff hunk that also references `chat.id` or a `*_CHAT_ID` constant
# (added line OR context line). Lean toward false positives; override env
# var lets you bypass when the design really doesn't need a chat-id gate.
if [ "$SKIP_CHATTYPE_CHECK" != "1" ]; then
    BAD_CHATTYPE=""
    for f in $(git diff --cached --name-only --diff-filter=ACM | grep -E '^bot/.*\.py$'); do
        if [ ! -f "$f" ]; then continue; fi
        # Did the staged change ADD a chat.type.in_ filter?
        if ! git diff --cached -- "$f" | grep -qE '^\+[^-].*chat\.type\.in_\('; then
            continue
        fi
        # If so, the same diff hunk (with 10-line context) must also reference
        # chat.id or a *_CHAT_ID constant somewhere.
        if ! git diff --cached -U10 -- "$f" | grep -qE '^[+ ].*(chat\.id|_CHAT_ID)'; then
            BAD_CHATTYPE="$BAD_CHATTYPE $f"
        fi
    done
    if [ -n "$BAD_CHATTYPE" ]; then
        echo "❌ HANDLER_ORDER_SWALLOW risk — chat.type.in_() filter added without a chat.id gate:"
        for f in $BAD_CHATTYPE; do echo "    $f"; done
        echo ""
        echo "   Sub-router handlers that catch a message shape (F.document,"
        echo "   F.photo, F.location, ...) in groups MUST gate by exact"
        echo "   chat.id == GROUP_CHAT_ID (or a chat-id-set from group_config),"
        echo "   never by chat.type alone — otherwise they eat messages from"
        echo "   every group the bot joins."
        echo "   Correct:"
        echo "     @router.message(F.document, F.chat.id == ADMIN_GROUP_CHAT_ID)"
        echo "     @router.message(F.document, F.chat.id.in_(ALL_OPS_GROUPS))"
        echo "   (Error Log #17/#28/#33 HANDLER_ORDER_SWALLOW;"
        echo "    rule in .claude/rules/06-bot-operations.md.)"
        echo "   Override (rare): SKIP_CHATTYPE_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Foundation guard 5: frontend fetch-discipline ────────────────────────
# All frontend API calls must go through frontend/src/utils/api.js so the
# initDataHeader (X-Telegram-Init-Data) is uniformly attached and the API
# surface stays auditable from one place. Inline `fetch('/api/...')` in
# pages/components is the drift class that produced 18+ scattered fetches
# in CabinetPage.jsx over time — surfaced by 2026-05-17 foundation audit.
# Heuristic: block any NEW inline fetch('/api/...) or fetch(`/api/...`) in
# frontend/src/{pages,components}/. Existing violations are grandfathered
# (tracked separately in Notion Command Center "Next (when convenient)").
if [ "$SKIP_INLINE_FETCH_CHECK" != "1" ]; then
    BAD_FETCH=""
    for f in $(git diff --cached --name-only --diff-filter=ACM | grep -E '^frontend/src/(pages|components)/.*\.(js|jsx)$'); do
        if [ ! -f "$f" ]; then continue; fi
        # Match added lines containing fetch( with /api/ in the URL — single quote,
        # double quote, or backtick (template literal).
        if git diff --cached -- "$f" | grep -qE "^\+[^-].*fetch\([\"'\`]/api/"; then
            BAD_FETCH="$BAD_FETCH $f"
        fi
    done
    if [ -n "$BAD_FETCH" ]; then
        echo "❌ Inline fetch('/api/...) added in a frontend page/component:"
        for f in $BAD_FETCH; do echo "    $f"; done
        echo ""
        echo "   All API calls should go through frontend/src/utils/api.js —"
        echo "   that's where initDataHeader (X-Telegram-Init-Data) is attached"
        echo "   uniformly. Inline fetches drift over time (CabinetPage.jsx grew"
        echo "   to 18+ scattered fetches that way)."
        echo "   Pattern: add an exported helper in api.js, import it in the page."
        echo "   Override (rare): SKIP_INLINE_FETCH_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Ruff lint ─────────────────────────────────────────────────────────────
# CI runs ruff too — running it locally first means the same drift class
# (unused imports, F821 undefined names) gets caught at commit time, not
# after a push round-trip. Hook precedes pytest because lint is cheap (~1s)
# and a lint error often reveals a typo that pytest would surface as a less
# clear failure.
if [ "$SKIP_RUFF" != "1" ]; then
    echo "🧹 Ruff lint..."
    if ! "$PY" -m ruff check backend bot 2>&1; then
        echo "❌ Ruff found issues. Fix or run \`$PY -m ruff check backend bot --fix\`."
        echo "   Override (rare): SKIP_RUFF=1 git commit ..."
        exit 1
    fi
fi

# ── Pytest ────────────────────────────────────────────────────────────────
# pytest.ini's testpaths covers both tests/ and backend/tests/, so a plain
# `pytest -q` runs both suites — the auth-fallback rot from 2026-05-10 is now
# loud rather than hiding behind manual invocation.
echo "🧪 Running tests..."
"$PY" -m pytest -q --tb=short 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Fix before committing."
    exit 1
fi

# ── Frontend build freshness ──────────────────────────────────────────────
# If any frontend/src file is staged but frontend/dist is NOT also staged,
# the committed bundle will drift from source. Rebuild + restage.
# Skip with SKIP_FRONTEND_BUILD=1 for docs-only or emergency commits.
STAGED_FE_SRC=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^frontend/(src|index\.html|vite\.config|package\.json)')

if [ -n "$STAGED_FE_SRC" ] && [ "$SKIP_FRONTEND_BUILD" != "1" ]; then
    echo "🏗  Frontend source changed — rebuilding dist/..."
    if [ ! -d "frontend/node_modules" ]; then
        echo "❌ frontend/node_modules missing. Run: cd frontend && npm install"
        exit 1
    fi
    (cd frontend && ./node_modules/.bin/vite build) >/dev/null 2>&1
    if [ $? -ne 0 ]; then
        echo "❌ Frontend build failed. Run 'cd frontend && npm run build' to see the error."
        exit 1
    fi
    # Enforce bundle budget from CLAUDE.md (<400K JS + <50K CSS main chunk).
    if [ "$SKIP_BUNDLE_CHECK" != "1" ]; then
        if ! "$PY" tools/check_bundle_size.py; then
            echo ""
            echo "   Override (rare): SKIP_BUNDLE_CHECK=1 git commit ..."
            exit 1
        fi
    fi
    # Re-stage the updated dist so the commit reflects the new bundle
    git add frontend/dist
    echo "✅ Frontend rebuilt, within budget & dist/ re-staged"
fi

echo "✅ All checks passed"
